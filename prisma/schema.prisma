generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String             @id @default(uuid())
  employeeId  String?            @unique
  fullName    String
  email       String?
  department  String?
  position    String?
  createdAt   DateTime           @default(now())
  assessments AssessmentRecord[]
}

model AssessmentRecord {
  id             String       @id @default(uuid())
  version        String
  assessmentDate DateTime
  resultData     Json
  answers        Json
  aiReport       Json?
  hrNote         String?
  exportedAt     DateTime?
  viewCount      Int          @default(0)
  lastViewedAt   DateTime?
  submissionIp   String?
  userId         String
  createdAt      DateTime     @default(now())
  questionSetId  String?
  questionSet    QuestionSet? @relation(fields: [questionSetId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model RateLimit {
  id        String   @id @default(uuid())
  key       String   @unique
  count     Int      @default(1)
  windowStart DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TargetRole {
  id           String        @id @default(uuid())
  code         String        @unique
  name         String
  description  String?
  createdAt    DateTime      @default(now())
  questionSets QuestionSet[]
}

model QuestionSet {
  id          String             @id @default(uuid())
  roleId      String
  version     String
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  assessments AssessmentRecord[]
  questions   Question[]
  role        TargetRole         @relation(fields: [roleId], references: [id])
}

model Question {
  id               String      @id @default(uuid())
  setId            String
  textVi           String
  textEn           String
  textJa           String
  dimensionId      String
  reversed         Boolean     @default(false)
  isLieScale       Boolean     @default(false)
  consistencyGroup String?
  createdAt        DateTime    @default(now())
  set              QuestionSet @relation(fields: [setId], references: [id])
}

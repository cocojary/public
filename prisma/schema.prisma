generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  employeeId      String?  @unique
  fullName        String
  email           String?
  department      String?
  position        String?
  assessments     AssessmentRecord[]
  createdAt       DateTime @default(now())
}

model AssessmentRecord {
  id              String   @id @default(uuid())
  version         String
  assessmentDate  DateTime
  resultData      Json
  answers         Json
  hrNote          String?  @db.Text
  exportedAt      DateTime?
  
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  questionSetId   String?
  questionSet     QuestionSet? @relation(fields: [questionSetId], references: [id])

  createdAt       DateTime @default(now())
}

model TargetRole {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  questionSets QuestionSet[]
  createdAt   DateTime @default(now())
}

model QuestionSet {
  id          String   @id @default(uuid())
  roleId      String
  role        TargetRole @relation(fields: [roleId], references: [id])
  version     String
  isActive    Boolean  @default(true)
  questions   Question[]
  assessments AssessmentRecord[]
  createdAt   DateTime @default(now())
}

model Question {
  id               String   @id @default(uuid())
  setId            String
  set              QuestionSet @relation(fields: [setId], references: [id])
  textVi           String
  textEn           String
  textJa           String
  dimensionId      String
  reversed         Boolean  @default(false)
  isLieScale       Boolean  @default(false)
  consistencyGroup String?
  createdAt        DateTime @default(now())
}
